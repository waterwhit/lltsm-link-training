<mxfile host="app.diagrams.net" modified="2026-07-10T00:00:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="lltsm-architecture" name="LLTSM两模块架构">
    <mxGraphModel dx="1800" dy="1250" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1250" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="LLTSM 两模块集成架构" style="text;html=1;strokeColor=none;fillColor=none;fontSize=30;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="50" y="30" width="900" height="45" as="geometry" /></mxCell>
        <mxCell id="subtitle" value="LLTSM_LINK 根据负载字段识别训练帧；MAC 不识别训练帧，只负责 CRC/FCS 状态和链路传输。" style="text;html=1;strokeColor=none;fillColor=none;fontSize=16;fontColor=#475569;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="50" y="78" width="1600" height="30" as="geometry" /></mxCell>

        <mxCell id="controller-layer" value="通信总线控制器" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#EAF2FF;strokeColor=#94A3B8;fontSize=24;fontStyle=1;align=left;verticalAlign=top;spacingLeft=18;spacingTop=12;" vertex="1" parent="1"><mxGeometry x="45" y="130" width="1710" height="350" as="geometry" /></mxCell>
        <mxCell id="top" value="&lt;b&gt;控制器 TOP / 主 FSM&lt;/b&gt;&lt;br&gt;&lt;br&gt;进入/退出 LLTSM 分支&lt;br&gt;冻结业务流量&lt;br&gt;选择链路、通道和训练轮次&lt;br&gt;超时、中止与结果存储" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#334155;strokeWidth=2;fontSize=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="105" y="225" width="430" height="180" as="geometry" /></mxCell>
        <mxCell id="fsm" value="&lt;b&gt;LLTSM_FSM&lt;/b&gt;&lt;br&gt;&lt;br&gt;训练分支状态调度&lt;br&gt;重复测量与 RTT 均值&lt;br&gt;固定应答延迟补偿&lt;br&gt;train_done 上报 TOP" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#2563EB;strokeWidth=2;fontSize=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="680" y="225" width="430" height="180" as="geometry" /></mxCell>
        <mxCell id="link" value="&lt;b&gt;LLTSM_LINK&lt;/b&gt;&lt;br&gt;&lt;br&gt;生成固定 128-bit TRAIN_FRAME&lt;br&gt;识别协议标识/保留位/固定图样&lt;br&gt;结合 crc_ok 校验并原样应答&lt;br&gt;锁存并上传接收时间戳" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#059669;strokeWidth=2;fontSize=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1260" y="225" width="430" height="180" as="geometry" /></mxCell>

        <mxCell id="fifo-layer" value="控制器 FIFO 与 MAC 边界" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ECFDF3;strokeColor=#94A3B8;fontSize=24;fontStyle=1;align=left;verticalAlign=top;spacingLeft=18;spacingTop=12;" vertex="1" parent="1"><mxGeometry x="45" y="520" width="1710" height="260" as="geometry" /></mxCell>
        <mxCell id="txfifo" value="&lt;b&gt;TX 异宽 FIFO&lt;/b&gt;&lt;br&gt;&lt;br&gt;LLTSM：128-bit 宽写口&lt;br&gt;MAC：本地数据位宽读口&lt;br&gt;整帧负载一次入队" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#334155;strokeWidth=2;fontSize=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="140" y="600" width="380" height="130" as="geometry" /></mxCell>
        <mxCell id="mac" value="&lt;b&gt;MAC / 链路传输&lt;/b&gt;&lt;br&gt;&lt;br&gt;不解析 LLTSM 负载字段&lt;br&gt;CRC/FCS 产生与校验&lt;br&gt;输出 crc_ok 与 RX 时间戳&lt;br&gt;选择 PHY 和通道" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#D97706;strokeWidth=2;fontSize=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="710" y="580" width="380" height="170" as="geometry" /></mxCell>
        <mxCell id="rxfifo" value="&lt;b&gt;RX 异宽 FIFO&lt;/b&gt;&lt;br&gt;&lt;br&gt;MAC：本地数据位宽写口&lt;br&gt;LLTSM：128-bit 宽读口&lt;br&gt;CRC 状态和时间戳对齐" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#334155;strokeWidth=2;fontSize=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1280" y="600" width="380" height="130" as="geometry" /></mxCell>

        <mxCell id="phy-layer" value="物理层" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#FFF7E6;strokeColor=#94A3B8;fontSize=24;fontStyle=1;align=left;verticalAlign=top;spacingLeft=18;spacingTop=12;" vertex="1" parent="1"><mxGeometry x="45" y="820" width="1710" height="210" as="geometry" /></mxCell>
        <mxCell id="phy" value="&lt;b&gt;选定 PHY 与相邻节点&lt;/b&gt;&lt;br&gt;&lt;br&gt;训练帧沿现有业务链路收发" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#334155;strokeWidth=2;fontSize=18;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="650" y="885" width="500" height="100" as="geometry" /></mxCell>
        <mxCell id="note" value="训练帧识别规则：字 0 为固定协议标识、保留位为 0、字 4～7 为固定图样；MAC 仅提供 CRC/FCS 结果。应答负载保持 128-bit 逐位不变。" style="text;html=1;strokeColor=none;fillColor=none;fontSize=16;fontColor=#DC2626;align=left;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="70" y="1065" width="1640" height="55" as="geometry" /></mxCell>

        <mxCell id="e-top-fsm" value="train_enable / start / abort&lt;br&gt;train_done / result_*" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeColor=#2563EB;strokeWidth=3;fontSize=14;fontColor=#475569;" edge="1" parent="1" source="top" target="fsm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-fsm-link" value="请求/原样应答命令&lt;br&gt;有效请求/应答时间戳" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeColor=#059669;strokeWidth=3;fontSize=14;fontColor=#475569;" edge="1" parent="1" source="fsm" target="link"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-link-tx" value="完整 128-bit 训练负载写入" style="endArrow=classic;html=1;rounded=0;strokeColor=#059669;strokeWidth=3;fontSize=14;fontColor=#475569;" edge="1" parent="1" source="link" target="txfifo"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1475" y="500" /><mxPoint x="330" y="500" /></Array></mxGeometry></mxCell>
        <mxCell id="e-tx-mac" value="窄口出队" style="endArrow=classic;html=1;rounded=0;strokeColor=#059669;strokeWidth=3;fontSize=14;fontColor=#475569;" edge="1" parent="1" source="txfifo" target="mac"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-mac-rx" value="去除链路字头与 CRC" style="endArrow=classic;html=1;rounded=0;strokeColor=#D97706;strokeWidth=3;fontSize=14;fontColor=#475569;" edge="1" parent="1" source="mac" target="rxfifo"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-rx-link" value="负载 + CRC 状态 + 时间戳" style="endArrow=classic;html=1;rounded=0;strokeColor=#D97706;strokeWidth=3;fontSize=14;fontColor=#475569;" edge="1" parent="1" source="rxfifo" target="link"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1470" y="500" /></Array></mxGeometry></mxCell>
        <mxCell id="e-mac-phy" value="链路帧" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeColor=#D97706;strokeWidth=3;fontSize=14;fontColor=#475569;" edge="1" parent="1" source="mac" target="phy"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
